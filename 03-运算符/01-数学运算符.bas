Sub MainSub()
    
    ' 基本使用
    Debug.Print 10 + 3  ' 13
    Debug.Print 10 - 3  ' 7
    Debug.Print 10 * 3  ' 30

    ' 浮点除法
    Debug.Print 5 / 2  ' 2.5
    ' 整数除法, 会直接取整数, 丢掉小数, 而不是四舍五入
    Debug.Print 5 \ 2  ' 2

    ' 取余数
    Debug.Print 10 Mod 3   ' 1
    ' 幂运算
    Debug.Print 2 ^ 4  ' 16

End Sub